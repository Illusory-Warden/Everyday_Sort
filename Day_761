private fun Int.toCompassDir(): String {
    val dirs = listOf("N", "NE", "E", "SE", "S", "SW", "W", "NW")
    return dirs[((this + 22) / 45) % 8]
}

private fun Double.uvLabel(): String = when {
    this < 3  -> "Low"
    this < 6  -> "Moderate"
    this < 8  -> "High"
    this < 11 -> "Very High"
    else      -> "Extreme"
}

private fun humidityLabel(h: Int): String = when {
    h < 30 -> "Very Dry"
    h < 50 -> "Comfortable"
    h < 70 -> "Moderate"
    h < 85 -> "Humid"
    else   -> "Very Humid"
}

private fun feelsLikeLabel(actual: Double, feels: Double): String = when {
    feels - actual > 3  -> "Warmer than actual"
    actual - feels > 3  -> "Cooler than actual"
    else                -> "Similar to actual"
}
