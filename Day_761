@Composable
private fun FarmInfoCard(
    crop: String,
    landSize: String,
    irrigation: String,
    language: String,
    strings: LanguageHelper.AppStrings
) {
    val emoji         = LanguageHelper.getCropEmoji(crop)
    val cropLocalName = LanguageHelper.getCropLocalName(crop, language)

    Card(
        modifier  = Modifier.fillMaxWidth().padding(horizontal = 16.dp),
        shape     = RoundedCornerShape(20.dp),
        colors    = CardDefaults.cardColors(containerColor = Color(0xFFE8F5E9)),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Row(
            modifier          = Modifier.padding(16.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            Box(
                modifier         = Modifier
                    .size(60.dp)
                    .background(Green900.copy(alpha = 0.1f), CircleShape),
                contentAlignment = Alignment.Center
            ) {
                Text(emoji, fontSize = 30.sp)
            }
            Spacer(modifier = Modifier.width(14.dp))
            Column(modifier = Modifier.weight(1f)) {
                Text(
                    text       = strings.myFarm,
                    color      = Green900.copy(alpha = 0.7f),
                    fontSize   = 11.sp,
                    fontWeight = FontWeight.SemiBold
                )
                Text(
                    text       = cropLocalName,
                    color      = Green900,
                    fontSize   = 22.sp,
                    fontWeight = FontWeight.Bold
                )
                if (cropLocalName != crop) {
                    Text(text = crop, color = Green900.copy(alpha = 0.55f), fontSize = 12.sp)
                }
            }
            Column(horizontalAlignment = Alignment.End) {
                if (landSize.isNotEmpty()) {
                    FarmChip("$landSize ${strings.acres}")
                    Spacer(modifier = Modifier.height(5.dp))
                }
                if (irrigation.isNotEmpty()) {
                    FarmChip(irrigation)
                }
            }
        }
    }
}

@Composable
private fun FarmChip(text: String) {
    Box(
        modifier = Modifier
            .background(Green900.copy(alpha = 0.1f), RoundedCornerShape(8.dp))
            .padding(horizontal = 10.dp, vertical = 5.dp)
    ) {
        Text(text, color = Green900, fontSize = 12.sp, fontWeight = FontWeight.Medium)
    }
}

