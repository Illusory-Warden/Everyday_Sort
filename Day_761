// ERROR / EMPTY STATE
// ══════════════════════════════════════════════════════════════════════════════
@Composable
private fun ErrorEmptyState(message: String, language: String, onRetry: () -> Unit) {
    // ── Dedicated offline-mode branch — this isn't an error, so it gets a
    // calmer tone, no warning icon, and points to what still works instead
    // of just offering retry (retrying without internet will just fail again).
    if (message == "OFFLINE_MODE") {
        val title = when (language) {
            "hi" -> "आप ऑफ़लाइन हैं"
            "mr" -> "तुम्ही ऑफलाइन आहात"
            else -> "You're Offline"
        }
        val subtitle = when (language) {
            "hi" -> "मौसम और AI सलाह के लिए इंटरनेट चाहिए। लेकिन सिंचाई सलाह अभी भी ऑफ़लाइन मोड में काम करती है।"
            "mr" -> "हवामान आणि AI सल्ल्यासाठी इंटरनेट लागते. पण सिंचन सल्ला ऑफलाइन मोडमध्येही काम करतो."
            else -> "Weather and AI advice need internet. Irrigation Advisory still works offline using the on-device model."
        }
        val retryLabelOffline = when (language) { "hi" -> "फिर कोशिश करें"; "mr" -> "पुन्हा प्रयत्न करा"; else -> "Try Again" }

        Card(
            modifier = Modifier
                .fillMaxWidth()
                .padding(horizontal = 16.dp),
            shape     = RoundedCornerShape(18.dp),
            colors    = CardDefaults.cardColors(containerColor = Color(0xFFEFF4EF)),
            elevation = CardDefaults.cardElevation(2.dp)
        ) {
            Column(
                modifier            = Modifier.fillMaxWidth().padding(24.dp),
                horizontalAlignment = Alignment.CenterHorizontally
            ) {
                Icon(
                    imageVector        = Icons.Default.CloudOff,
                    contentDescription = null,
                    tint               = Color(0xFF5C7A5C),
                    modifier           = Modifier.size(36.dp)
                )
                Spacer(modifier = Modifier.height(10.dp))
                Text(
                    text       = title,
                    fontSize   = 15.sp,
                    fontWeight = FontWeight.SemiBold,
                    color      = Color(0xFF33463A),
                    textAlign  = TextAlign.Center
                )
                Spacer(modifier = Modifier.height(6.dp))
                Text(
                    text      = subtitle,
                    fontSize  = 12.sp,
                    color     = Color(0xFF5C7A5C),
                    textAlign = TextAlign.Center
                )
                Spacer(modifier = Modifier.height(16.dp))
                Button(
                    onClick  = onRetry,
                    colors   = ButtonDefaults.buttonColors(containerColor = Green900),
                    shape    = RoundedCornerShape(10.dp)
                ) {
                    Icon(Icons.Default.Refresh, null, tint = Color.White, modifier = Modifier.size(16.dp))
                    Spacer(modifier = Modifier.width(6.dp))
                    Text(retryLabelOffline, color = Color.White, fontWeight = FontWeight.Bold)
                }
            }
        }
        return
    }

    // ── Genuine error branch (unchanged, plus a timeout-specific hint) ────
    val retryLabel = when (language) { "hi" -> "फिर कोशिश करें"; "mr" -> "पुन्हा प्रयत्न करा"; else -> "Try Again" }
    val hint = when {
        message.contains("location", ignoreCase = true) || message.contains("GPS", ignoreCase = true) ->
            when (language) { "hi" -> "GPS चालू करें और फिर कोशिश करें"; "mr" -> "GPS चालू करा आणि पुन्हा प्रयत्न करा"; else -> "Please enable GPS and try again" }
        message.contains("internet", ignoreCase = true) || message.contains("host", ignoreCase = true) || message.contains("network", ignoreCase = true) ->
            when (language) { "hi" -> "इंटरनेट कनेक्शन जांचें"; "mr" -> "इंटरनेट कनेक्शन तपासा"; else -> "Check your internet connection" }
        message.contains("too long", ignoreCase = true) || message.contains("timed", ignoreCase = true) ->
            when (language) { "hi" -> "कनेक्शन धीमा है, दोबारा कोशिश करें"; "mr" -> "कनेक्शन संथ आहे, पुन्हा प्रयत्न करा"; else -> "Connection seems slow, please retry" }
        else ->
            when (language) { "hi" -> "कुछ गलत हुआ, दोबारा कोशिश करें"; "mr" -> "काहीतरी चुकले, पुन्हा प्रयत्न करा"; else -> "Something went wrong, please retry" }
    }

    Card(
        modifier = Modifier
            .fillMaxWidth()
            .padding(horizontal = 16.dp),
        shape     = RoundedCornerShape(18.dp),
        colors    = CardDefaults.cardColors(containerColor = Color(0xFFFFF3E0)),
        elevation = CardDefaults.cardElevation(2.dp)
    ) {
        Column(
            modifier          = Modifier
                .fillMaxWidth()
                .padding(24.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            Text("⚠️", fontSize = 40.sp)
            Spacer(modifier = Modifier.height(10.dp))
            Text(
                text       = hint,
                fontSize   = 15.sp,
                fontWeight = FontWeight.SemiBold,
                color      = Color(0xFF5D4037),
                textAlign  = TextAlign.Center
            )
            Spacer(modifier = Modifier.height(6.dp))
            Text(
                text      = message,
                fontSize  = 12.sp,
                color     = Color(0xFF8D6E63),
                textAlign = TextAlign.Center
            )
            Spacer(modifier = Modifier.height(16.dp))
            Button(
                onClick  = onRetry,
                colors   = ButtonDefaults.buttonColors(containerColor = Color(0xFFE65100)),
                shape    = RoundedCornerShape(10.dp)
            ) {
                Icon(Icons.Default.Refresh, null, tint = Color.White, modifier = Modifier.size(16.dp))
                Spacer(modifier = Modifier.width(6.dp))
                Text(retryLabel, color = Color.White, fontWeight = FontWeight.Bold)
            }
        }
    }
}

