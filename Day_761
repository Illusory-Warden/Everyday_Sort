// SHIMMER HELPER
// ══════════════════════════════════════════════════════════════════════════════
@Composable
fun shimmerBrush(): Brush {
    val shimmerColors = listOf(
        Color(0xFFE0E0E0),
        Color(0xFFF5F5F5),
        Color(0xFFE0E0E0)
    )
    val transition = rememberInfiniteTransition(label = "shimmer")
    val translateAnim by transition.animateFloat(
        initialValue   = 0f,
        targetValue    = 1000f,
        animationSpec  = infiniteRepeatable(
            animation = tween(durationMillis = 1200, easing = LinearEasing),
            repeatMode = RepeatMode.Restart
        ),
        label = "shimmerTranslate"
    )
    return Brush.linearGradient(
        colors = shimmerColors,
        start  = Offset(translateAnim - 400f, 0f),
        end    = Offset(translateAnim, 0f)
    )
}

@Composable
private fun ShimmerBox(modifier: Modifier) {
    Box(modifier = modifier.background(shimmerBrush(), RoundedCornerShape(12.dp)))
}

// ══════════════════════════════════════════════════════════════════════════════
// MAIN SCREEN
// ══════════════════════════════════════════════════════════════════════════════
@Composable
fun MainScreen(navController: NavController) {

    val context       = LocalContext.current
    val viewModel: HomeViewModel = viewModel()
    val uiState    by viewModel.uiState.collectAsState()
    val farmerName by viewModel.farmerName.collectAsState()
    val crop       by viewModel.crop.collectAsState()
    val language   by viewModel.language.collectAsState()
    val landSize   by viewModel.landSize.collectAsState()
    val irrigation by viewModel.irrigation.collectAsState()

    val strings = LanguageHelper.getStrings(language)

    val lifecycleOwner = LocalLifecycleOwner.current
    DisposableEffect(lifecycleOwner) {
        val observer = LifecycleEventObserver { _, event ->
            if (event == Lifecycle.Event.ON_RESUME) {
                viewModel.reloadPrefs(context)
            }
        }
        lifecycleOwner.lifecycle.addObserver(observer)
        onDispose { lifecycleOwner.lifecycle.removeObserver(observer) }
    }

    LaunchedEffect(Unit) {
        viewModel.loadData(context)
    }

    Box(
        modifier = Modifier
            .fillMaxSize()
            .background(Color(0xFFF0F4F0))
    ) {
        Column(
            modifier = Modifier
                .fillMaxSize()
                .verticalScroll(rememberScrollState())
        ) {

            // ── Top Header ──────────────────────────────────────────────────
            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .background(
                        brush = Brush.verticalGradient(
                            colors = listOf(Color(0xFF2D5016), Green900)
                        )
                    )
                    .statusBarsPadding()
                    .padding(horizontal = 20.dp, vertical = 18.dp)
            ) {
                Column {
                    Row(
                        verticalAlignment = Alignment.CenterVertically,
                        modifier          = Modifier.fillMaxWidth()
                    ) {
                        Column(modifier = Modifier.weight(1f)) {
                            Text(
                                text       = "${strings.greeting}, $farmerName!",
                                color      = Color.White,
                                fontSize   = 20.sp,
                                fontWeight = FontWeight.Bold
                            )
                            Text(
                                text     = strings.todayReport,
                                color    = Color.White.copy(alpha = 0.72f),
                                fontSize = 13.sp
                            )
                        }
                        IconButton(
                            onClick  = { navController.navigate(NavGraph.SETTINGS) },
                            modifier = Modifier
                                .size(42.dp)
                                .background(Color.White.copy(alpha = 0.18f), CircleShape)
                        ) {
                            Icon(
                                imageVector        = Icons.Default.Settings,
                                contentDescription = strings.settings,
                                tint               = Color.White,
                                modifier           = Modifier.size(22.dp)
                            )
                        }
                    }
                    if (!uiState.isLoadingWeather && uiState.locationName.isNotEmpty()) {
                        Spacer(modifier = Modifier.height(6.dp))
                        Row(verticalAlignment = Alignment.CenterVertically) {
                            Icon(
                                Icons.Default.LocationOn,
                                contentDescription = null,
                                tint               = Color.White.copy(alpha = 0.75f),
                                modifier           = Modifier.size(14.dp)
                            )
                            Spacer(modifier = Modifier.width(4.dp))
                            Text(
                                text     = uiState.locationName,
                                color    = Color.White.copy(alpha = 0.75f),
                                fontSize = 13.sp
                            )
                        }
                    }
                }
            }

            Spacer(modifier = Modifier.height(14.dp))

            // ── ERROR / EMPTY STATE ─────────────────────────────────────────
            if (uiState.errorMessage != null && !uiState.isLoadingWeather) {
                ErrorEmptyState(
                    message  = uiState.errorMessage!!,
                    language = language,
                    onRetry  = { viewModel.refresh(context) }
                )
                Spacer(modifier = Modifier.height(14.dp))
            }

            // ── Farm Info Card ──────────────────────────────────────────────
            if (crop != "General" || landSize.isNotEmpty()) {
                FarmInfoCard(
                    crop       = crop,
                    landSize   = landSize,
                    irrigation = irrigation,
                    language   = language,
                    strings    = strings
                )
                Spacer(modifier = Modifier.height(12.dp))
            }

            // ── Irrigation Advisory Button ──────────────────────────────────
            val irrigationLabel = when (language) {
                "hi" -> "💧 सिंचाई सलाह देखें"
                "mr" -> "💧 सिंचन सल्ला पाहा"
                else -> "💧 View Irrigation Advisory"
            }
            val irrigationSub = when (language) {
                "hi" -> "AI आधारित सिंचाई निर्णय सहायता"
                "mr" -> "AI आधारित सिंचन निर्णय सहाय्य"
                else -> "AI-Based Irrigation Decision Support"
            }

            Card(
                onClick   = { navController.navigate(NavGraph.IRRIGATION) },
                modifier  = Modifier
                    .fillMaxWidth()
                    .padding(horizontal = 16.dp),
                shape     = RoundedCornerShape(18.dp),
                colors    = CardDefaults.cardColors(containerColor = Color(0xFF1B4332)),
                elevation = CardDefaults.cardElevation(4.dp)
            ) {
                Row(
                    modifier          = Modifier
                        .fillMaxWidth()
                        .padding(horizontal = 20.dp, vertical = 16.dp),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Column(modifier = Modifier.weight(1f)) {
                        Text(
                            text       = irrigationLabel,
                            color      = Color.White,
                            fontSize   = 15.sp,
                            fontWeight = FontWeight.Bold
                        )
                        Spacer(modifier = Modifier.height(2.dp))
                        Text(
                            text     = irrigationSub,
                            color    = Color.White.copy(alpha = 0.75f),
                            fontSize = 12.sp
                        )
                    }
                    Icon(
                        imageVector        = Icons.Default.ArrowForward,
                        contentDescription = null,
                        tint               = Color.White,
                        modifier           = Modifier.size(22.dp)
                    )
                }
            }
            Spacer(modifier = Modifier.height(12.dp))

            // ── Weather Hero (shimmer while loading) ────────────────────────
            if (uiState.isLoadingWeather) {
                WeatherShimmer()
            } else if (uiState.errorMessage == null) {
                WeatherHeroCard(uiState = uiState, strings = strings)
            }
            Spacer(modifier = Modifier.height(12.dp))

            // ── Stats Grid (shimmer while loading) ──────────────────────────
            if (uiState.isLoadingWeather) {
                StatsShimmer()
            } else if (uiState.errorMessage == null) {
                StatsGrid(uiState = uiState, strings = strings)
                Spacer(modifier = Modifier.height(12.dp))
                SunInfoCard(uiState = uiState, strings = strings)
            }
            Spacer(modifier = Modifier.height(12.dp))

            // ── AI Insights ─────────────────────────────────────────────────
            AiInsightsCard(
                uiState  = uiState,
                crop     = crop,
                language = language,
                strings  = strings
            )
            Spacer(modifier = Modifier.height(12.dp))

            // ── 5-Day Forecast ──────────────────────────────────────────────
            if (!uiState.isLoadingWeather && uiState.dailyForecast.isNotEmpty() && uiState.errorMessage == null) {
                ForecastCard(forecast = uiState.dailyForecast, strings = strings)
                Spacer(modifier = Modifier.height(12.dp))
            }

            // ── Refresh ─────────────────────────────────────────────────────
            OutlinedButton(
                onClick  = { viewModel.refresh(context) },
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(horizontal = 16.dp)
                    .height(48.dp),
                shape  = RoundedCornerShape(12.dp),
                border = BorderStroke(1.5.dp, Green900)
            ) {
                Icon(Icons.Default.Refresh, null, tint = Green900, modifier = Modifier.size(18.dp))
                Spacer(modifier = Modifier.width(8.dp))
                Text(strings.refresh, color = Green900, fontWeight = FontWeight.Medium)
            }

            Spacer(modifier = Modifier.height(28.dp))
        }
    }
}

