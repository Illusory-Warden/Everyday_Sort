// 5-DAY FORECAST CARD
// ══════════════════════════════════════════════════════════════════════════════
@Composable
private fun ForecastCard(forecast: List<DailyForecast>, strings: LanguageHelper.AppStrings) {
    Card(
        modifier  = Modifier.fillMaxWidth().padding(horizontal = 16.dp),
        shape     = RoundedCornerShape(20.dp),
        colors    = CardDefaults.cardColors(containerColor = Color.White),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(modifier = Modifier.padding(16.dp)) {
            Text(strings.forecast, fontWeight = FontWeight.Bold, fontSize = 14.sp, color = Color(0xFF1A1A2E))
            Spacer(modifier = Modifier.height(10.dp))
            forecast.forEachIndexed { index, day ->
                Row(
                    modifier          = Modifier.fillMaxWidth().padding(vertical = 8.dp),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Text(day.dayName, modifier = Modifier.width(48.dp), fontWeight = FontWeight.SemiBold, fontSize = 14.sp, color = Color(0xFF1A1A2E))
                    AsyncImage(
                        model              = "https://openweathermap.org/img/wn/${day.conditionIcon}@2x.png",
                        contentDescription = null,
                        modifier           = Modifier.size(36.dp)
                    )
                    Spacer(modifier = Modifier.width(6.dp))
                    Text(day.conditionDesc.replaceFirstChar { it.uppercase() }, color = Color.Gray, fontSize = 13.sp, modifier = Modifier.weight(1f))
                    Text("${day.tempMax.toInt()}°", fontWeight = FontWeight.Bold, fontSize = 15.sp, color = Color(0xFF1A1A2E))
                    Text(" / ${day.tempMin.toInt()}°", fontSize = 14.sp, color = Color.Gray)
                }
                if (index < forecast.size - 1) HorizontalDivider(color = Color(0xFFF0F0F0))
            }
        }
    }
}

