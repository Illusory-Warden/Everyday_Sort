// AI INSIGHTS CARD
// ══════════════════════════════════════════════════════════════════════════════
@Composable
private fun AiInsightsCard(
    uiState: HomeUiState,
    crop: String,
    language: String,
    strings: LanguageHelper.AppStrings
) {
    val cropEmoji     = LanguageHelper.getCropEmoji(crop)
    val cropLocalName = LanguageHelper.getCropLocalName(crop, language)
    val titleText     = if (crop == "General") strings.aiAdviceFor
    else "${strings.aiAdviceFor}  $cropEmoji $cropLocalName"

    Card(
        modifier  = Modifier.fillMaxWidth().padding(horizontal = 16.dp),
        shape     = RoundedCornerShape(20.dp),
        colors    = CardDefaults.cardColors(containerColor = Color.White),
        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp)
    ) {
        Column(modifier = Modifier.padding(16.dp)) {
            Row(verticalAlignment = Alignment.CenterVertically, modifier = Modifier.fillMaxWidth()) {
                Text("🤖", fontSize = 20.sp)
                Spacer(modifier = Modifier.width(8.dp))
                Text(
                    text       = titleText,
                    fontWeight = FontWeight.Bold,
                    fontSize   = 14.sp,
                    color      = Color(0xFF1A1A2E),
                    modifier   = Modifier.weight(1f)
                )
                if (!uiState.isLoadingInsights && uiState.insightSource.isNotEmpty()) {
                    val badgeColor = when (uiState.insightSource) {
                        "Groq"   -> Color(0xFF6366F1)
                        "Gemini" -> Color(0xFF4285F4)
                        else     -> Color.Gray
                    }
                    Box(
                        modifier = Modifier
                            .background(badgeColor.copy(alpha = 0.1f), RoundedCornerShape(6.dp))
                            .padding(horizontal = 8.dp, vertical = 3.dp)
                    ) {
                        Text(uiState.insightSource, color = badgeColor, fontSize = 11.sp, fontWeight = FontWeight.SemiBold)
                    }
                }
            }
            Spacer(modifier = Modifier.height(10.dp))
            HorizontalDivider(color = Color(0xFFEEEEEE))
            Spacer(modifier = Modifier.height(12.dp))

            if (uiState.isLoadingInsights) {
                // Shimmer for AI insights
                val brush = shimmerBrush()
                Column(verticalArrangement = Arrangement.spacedBy(8.dp)) {
                    Box(modifier = Modifier.fillMaxWidth().height(16.dp).background(brush, RoundedCornerShape(8.dp)))
                    Box(modifier = Modifier.fillMaxWidth(0.85f).height(16.dp).background(brush, RoundedCornerShape(8.dp)))
                    Box(modifier = Modifier.fillMaxWidth(0.9f).height(16.dp).background(brush, RoundedCornerShape(8.dp)))
                }
            } else {
                val lines = (uiState.aiInsight ?: strings.noData)
                    .lines()
                    .map { it.trim() }
                    .filter { it.isNotEmpty() }

                lines.forEach { line ->
                    Row(modifier = Modifier.padding(vertical = 5.dp), verticalAlignment = Alignment.Top) {
                        Text("•", color = Green900, fontSize = 18.sp, fontWeight = FontWeight.Bold, modifier = Modifier.padding(top = 0.dp, end = 10.dp))
                        Text(
                            text       = line.trimStart('•', '*', '-', ' ').trim(),
                            color      = Color(0xFF2D2D2D),
                            fontSize   = 14.sp,
                            lineHeight = 22.sp,
                            modifier   = Modifier.weight(1f)
                        )
                    }
                }
            }
        }
    }
}

